# Sandbox control plane URLs (us-east-2 stack: dungeon-agent-control-plane-sandbox)
# Fill from CloudFormation outputs ApiUrl and WebSocketUrl:
#   aws cloudformation describe-stacks \
#     --stack-name dungeon-agent-control-plane-sandbox \
#     --region us-east-2 \
#     --query 'Stacks[0].Outputs'
VITE_HTTP_URL=https://example.execute-api.us-east-2.amazonaws.com
VITE_WS_URL=wss://example.execute-api.us-east-2.amazonaws.com/prod
